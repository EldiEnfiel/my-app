AISSTREAM_API_KEY=replace-with-your-aisstream-api-key
AISSTREAM_INITIAL_WAIT_MS=4500
AISSTREAM_CACHE_TTL_MS=1200000
AISSTREAM_CACHE_MAX_RECORDS=12000
AISSTREAM_RESPONSE_MAX_RECORDS=6000
AISSTREAM_RECONNECT_DELAY_MS=3000
